FROM python:3.13.6-slim-bullseye

# uv: fast, reproducible installs from pyproject.toml + uv.lock
COPY --from=ghcr.io/astral-sh/uv:0.11.15 /uv /uvx /bin/

WORKDIR /app/backend

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV UV_COMPILE_BYTECODE=1
ENV UV_LINK_MODE=copy
# Keep the venv OUTSIDE /app/backend: docker-compose.dev mounts ./backend over
# it, which would otherwise shadow an in-tree .venv at runtime.
ENV UV_PROJECT_ENVIRONMENT=/opt/venv
ENV PATH="/opt/venv/bin:$PATH"

RUN apt-get update && \
    apt-get install -y libjpeg-dev && \
    apt-get install -y zlib1g-dev && \
    apt-get install -y libpng-dev

COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev

COPY ./bin/entrypoint.sh ./bin/entrypoint.sh
RUN sed -i 's/\r$//g' /app/backend/bin/entrypoint.sh
RUN chmod +x /app/backend/bin/entrypoint.sh

COPY . .

ENTRYPOINT ["/app/backend/bin/entrypoint.sh"]
